{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/node_modules/**", "test_engine.js", "firebaseConfig.txt", "README.md", "art/ART_DIRECTION.md"],
    "headers": [
      {
        "source": "**/*.@(html|js)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "**/*.@(png|webp|svg)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800" }]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
